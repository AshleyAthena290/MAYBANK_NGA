    {
      "sheet_name": "getDashboardState",
      "service": "getDashboardState",
      "description": "Retrieve aggregated App Dashboard response based on resolved state (POST_LOGIN / COOLING_OFF / PRE_LOGIN / PRE_BIND).",
      "business_rule": "Istio Ingress forwards the call to NGA Channel Layer. Channel Layer resolves the state from token introspect + device binding + customerClass + regFlags, runs a version check against NGBO, then composes the response (applying Proxy/Masking for pre-login / cooling-off). Pre-login and public snapshots are cached in Hazelcast (TTL 5 / 10 min).",
      "method": "GET",
      "url": "/v1/dashboard/state",
      "message_type": "JSON",
      "headers": [],
      "body_params": [],
      "query_params": [],
      "response_fields": []
    },
